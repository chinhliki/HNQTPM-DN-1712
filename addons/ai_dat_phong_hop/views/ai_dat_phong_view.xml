<odoo>
    <data>
        <!-- Form View for AI Interaction Session -->
        <record id="view_ai_dat_phong_form" model="ir.ui.view">
            <field name="name">ai_dat_phong_form</field>
            <field name="model">ai_dat_phong</field>
            <field name="arch" type="xml">
                <form string="🤖 Trợ lý Đặt Phòng AI">
                    <header>
                        <!-- Nút để mở Chat hoặc chat trực tiếp -->
                        <button name="action_confirm_booking" string="🚀 Xác nhận Đặt Phòng (Dựa trên trí tuệ nhân tạo)" type="object" class="oe_highlight"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <h1><field name="name"/></h1>
                        </div>
                        <group>
                            <group string="💬 Trò chuyện với Trợ lý Gemini">
                                <field name="chat_bubbles_html" nolabel="1"/>
                                <div class="o_row" style="display: flex; gap: 5px; margin-top: 10px;">
                                    <field name="new_user_input" nolabel="1" placeholder="Nhập tin nhắn tại đây..." style="flex-grow: 1;"/>
                                    <button name="action_send_direct_message" string="Gửi ✈️" type="object" class="btn-primary"/>
                                </div>
                            </group>
                            <group string="📋 Đề xuất từ Trợ lý AI">
                                <label for="phong_id" string="Phòng họp"/>
                                <div class="o_row">
                                    <field name="phong_id" options="{'no_create': True}" placeholder="Chờ AI gợi ý..."/>
                                </div>
                                <label for="nguoi_muon_id" string="Người mượn"/>
                                <div class="o_row">
                                    <field name="nguoi_muon_id" options="{'no_create': True}" placeholder="Chờ AI nhận diện..."/>
                                </div>
                                <field name="thoi_gian_muon" string="Giờ bắt đầu"/>
                                <field name="thoi_gian_tra" string="Giờ kết thúc"/>
                                <field name="so_luong_nguoi" string="Số người"/>
                                
                                <div style="margin-top: 20px; border-top: 1px solid #eee; padding-top: 15px;">
                                    <button name="action_confirm_booking" string="✅ Xác nhận &amp; Đặt phòng ngay" 
                                            type="object" class="btn-success" style="width: 100%; font-weight: bold; height: 45px;"
                                            attrs="{'invisible': [('phong_id', '=', False)]}"/>
                                </div>
                            </group>
                        </group>
                        <notebook>
                            <page string="🗨 Chat trực tiếp">
                                <group>
                                    <field name="chat_history" widget="text" nolabel="1" style="height: 300px; color: #555; background: #f9f9f9; padding: 10px; border-radius: 5px;"/>
                                </group>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Tree View -->
        <record id="view_ai_dat_phong_tree" model="ir.ui.view">
            <field name="name">ai_dat_phong_tree</field>
            <field name="model">ai_dat_phong</field>
            <field name="arch" type="xml">
                <tree string="📜 Lịch sử hỗ trợ AI">
                    <field name="create_date" string="Ngày tạo"/>
                    <field name="name" string="Tiêu đề"/>
                    <field name="user_id"/>
                    <field name="phong_id"/>
                </tree>
            </field>
        </record>

        <!-- Action Đặt phòng AI -->
        <record id="action_ai_dat_phong" model="ir.actions.act_window">
            <field name="name">🤖 Trợ lý Chat Đặt Phòng AI</field>
            <field name="res_model">ai_dat_phong</field>
            <field name="view_mode">tree,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Bắt đầu hội thoại với AI để được gợi ý phòng họp!
                </p>
                <p>
                    AI có thể hỗ trợ tìm phòng trống theo sức chứa và thời gian bạn mong muốn.
                </p>
            </field>
        </record>

        <!-- Wizard Chat View -->
        <record id="view_ai_chat_wizard_form" model="ir.ui.view">
            <field name="name">ai_chat_wizard_form</field>
            <field name="model">ai_chat_wizard</field>
            <field name="arch" type="xml">
                <form string="Chat với Trợ lý Gemini">
                    <sheet>
                        <div style="background: #f0f2f5; padding: 15px; border-radius: 8px; margin-bottom: 15px;">
                            <field name="ai_response" widget="text" nolabel="1" readonly="1" 
                                   placeholder="Trợ lý đang chờ câu hỏi của bạn..."
                                   style="background: transparent; border: none; font-style: italic; color: #555;"/>
                        </div>
                        <group>
                            <field name="user_message" string="Nội dung tin nhắn" 
                                   placeholder="Gõ nội dung tại đây (VD: Tôi muốn đặt phòng họp...)"/>
                        </group>
                    </sheet>
                    <footer>
                        <button name="action_send_message" string="Gửi tin nhắn ✈️" type="object" class="btn-primary"/>
                        <button string="Đóng" class="btn-secondary" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>

        <!-- Menuitem linking -->
        <menuitem id="menu_ai_dat_phong_root"
                  name="🤖 AI Trợ Lý (Gemini)"
                  parent="quan_li_phong_hop_hoi_truong.menu_root"
                  action="action_ai_dat_phong"
                  sequence="100"/>
    </data>
</odoo>
