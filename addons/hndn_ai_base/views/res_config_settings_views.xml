<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.hndn.ai</field>
        <field name="model">res.config.settings</field>
        <field name="priority" eval="20"/>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[hasclass('settings')]" position="inside">
                <div class="app_settings_block" data-string="HNDN AI" string="HNDN AI" data-key="hndn_ai_base_config">
                    <h2>Cấu hình Gemini AI</h2>
                    <div class="row mt16 o_settings_container">
                        <div class="col-12 col-lg-6 o_setting_box">
                            <div class="o_setting_right_pane">
                                <label for="hndn_gemini_api_key"/>
                                <field name="hndn_gemini_api_key" password="True"/>
                                <button name="action_test_gemini_connection" type="object" string="Kiểm tra kết nối" class="btn-link" icon="fa-arrow-right"/>
                                <div class="text-muted">Nhập API Key từ Google AI Studio.</div>
                            </div>
                        </div>
                    </div>
                </div>
            </xpath>
        </field>
    </record>

    <record id="action_hndn_ai_config_settings" model="ir.actions.act_window">
        <field name="name">Cấu hình AI</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">res.config.settings</field>
        <field name="view_mode">form</field>
        <field name="target">inline</field>
        <field name="context">{'module': 'hndn_ai_base_config'}</field>
    </record>
</odoo>
