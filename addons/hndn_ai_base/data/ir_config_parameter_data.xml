<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- API Key được nhập qua giao diện: Settings → HNDN AI → Cấu hình Gemini AI -->
    <!-- Không hardcode key ở đây nữa để bảo mật và linh hoạt hơn -->
    <data noupdate="1">
        <record id="gemini_api_key_parameter" model="ir.config_parameter">
            <field name="key">hndn_ai_base.hndn_gemini_api_key</field>
            <field name="value"></field>
        </record>
    </data>
</odoo>
